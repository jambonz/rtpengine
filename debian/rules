#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE = 1

include /usr/share/dpkg/pkg-info.mk

export DEB_VERSION_UPSTREAM
export DEB_SOURCE

ifneq (,$(filter $(DEB_BUILD_PROFILES),pkg.jambonz-rtpengine.no-transcoding))
export with_transcoding = no
endif
ifneq (,$(filter $(DEB_BUILD_PROFILES),pkg.jambonz-rtpengine.asan))
export DO_ASAN_FLAGS = 1
# this prevents dh from setting default (including -O2) which we don't want
export DEB_CFLAGS_MAINT_SET =
export DEB_LDFLAGS_MAINT_SET =
endif

export deb_systemdsystemunitdir := $(shell pkg-config --variable=systemdsystemunitdir systemd)

%:
	dh $@

execute_before_dh_auto_install-indep:
	# markdown README (used by debian/clean cleanup; harmless if file isn't shipped)
	markdown README.md | gzip -9 > debian/README.html.gz
	gzip -9 < README.md > debian/README.md.gz

# DKMS package is named jambonz-rtpengine-dkms (not <source>-kernel-dkms
# as upstream uses); pass an explicit -p so dh_dkms picks the right one.
override_dh_dkms:
	dh_dkms -pjambonz-rtpengine-dkms -V $(DEB_VERSION_UPSTREAM)

# The unit file debian/jambonz-rtpengine.rtpengine.service installs as
# rtpengine.service (kept under the long-standing "rtpengine" name so the
# monitoring agent, jambonz-updater and deploy automation that reference
# `systemctl ... rtpengine` keep working). Be explicit so it's reliably
# installed/enabled/started under that name.
override_dh_installsystemd:
	dh_installsystemd --name=rtpengine
